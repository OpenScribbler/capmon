{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openscribbler.github.io/capmon/v1/schemas/index.json",
  "schema_version": "1",
  "title": "v1 per-major discovery index",
  "description": "v1/index.json. source_commit is optional (omitted when unset); the freeze fields superseded_by/frozen_at are OPTIONAL from initial publication so the freeze mutation cannot invalidate a document against the pinned v1 schema.",
  "type": "object",
  "required": [
    "schema_version",
    "status",
    "generated_at",
    "cadence",
    "max_staleness_hours",
    "data_revision",
    "providers",
    "files"
  ],
  "properties": {
    "schema_version": {"type": "string"},
    "status": {"type": "string"},
    "generated_at": {"type": "string"},
    "cadence": {"type": "string"},
    "max_staleness_hours": {"type": "integer"},
    "data_revision": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "source_commit": {"type": "string"},
    "superseded_by": {"type": "string"},
    "frozen_at": {"type": "string"},
    "providers": {
      "type": "array",
      "items": {"$ref": "#/$defs/providerEntry"}
    },
    "files": {
      "type": "object",
      "additionalProperties": {"$ref": "#/$defs/fileEntry"}
    }
  },
  "$defs": {
    "providerEntry": {
      "type": "object",
      "required": ["slug", "path", "status", "sha256"],
      "properties": {
        "slug": {"type": "string"},
        "path": {"type": "string"},
        "status": {"type": "string"},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "last_verified": {"type": "string"},
        "removed_at": {"type": "string"}
      }
    },
    "fileEntry": {
      "type": "object",
      "required": ["sha256"],
      "properties": {
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    }
  }
}
